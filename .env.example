APP_ENV=dev
HOST=0.0.0.0
PORT=8000

# OpenRouter LLM config (optional)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=Financial Asset QA System

# Web search
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=3

# Knowledge base
KB_DIR=app/data/knowledge_base
KB_CHUNK_SIZE=500
KB_CHUNK_OVERLAP=80
KB_MAX_CHUNKS=20000
